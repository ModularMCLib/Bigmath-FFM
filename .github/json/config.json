{
  "categories": [
    {
      "title": "### Added",
      "labels": ["type: feature"]
    },
    {
      "title": "### Fixed",
      "labels": ["type: bugfix"]
    },
    {
      "title": "### Changed",
      "labels": ["type: refactor", "type: build", "type: ci", "type: docs"]
    }
  ],
  "sort": "ASC",
  "template": "## [v#{{VERSION}}](https://github.com/ModularMCLib/Bigmath-FFM/releases/tag/v#{{VERSION}})\n#{{CHANGELOG}}",
  "pr_template": "- #{{TITLE}} by @#{{AUTHOR}} in [#{{NUMBER}}](https://github.com/ModularMCLib/Bigmath-FFM/pull/#{{NUMBER}})",
  "custom_placeholders": [
    {
      "name": "VERSION",
      "source": "TO_TAG",
      "transformer": {
        "pattern": "v?([0-9\\.]+)(-[0-9\\.]+)?",
        "target": "$1"
      }
    }
  ],
  "empty_template": "- No changes",
  "ignore_labels": ["ignore changelog"],
  "tag_resolver": {
    "method": "semver",
    "filter": {
      "pattern": "^(?!v?[0-9\\.]+$).+$",
      "flags": "gu"
    },
    "transformer": {
      "pattern": "v?([0-9\\.]+)(-[0-9\\.]+)?",
      "target": "$1"
    }
  },
  "max_pull_requests": 500,
  "max_back_track_time_days": 180,
  "base_branches": ["26.1", "main"]
}
