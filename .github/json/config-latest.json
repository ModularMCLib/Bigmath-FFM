{
  "categories": [
    {
      "title": "### Added",
      "labels": ["type: feature"]
    },
    {
      "title": "### Fixed",
      "labels": ["type: bugfix"]
    },
    {
      "title": "### Changed",
      "labels": ["type: refactor", "type: build", "type: ci", "type: docs"]
    }
  ],
  "sort": "ASC",
  "template": "## Changes since last release\n#{{CHANGELOG}}\n#{{UNCATEGORIZED}}",
  "pr_template": "- #{{TITLE}} by @#{{AUTHOR}} in [#{{NUMBER}}](https://github.com/ModularMCLib/Bigmath-FFM/pull/#{{NUMBER}})",
  "empty_template": "- No significant changes",
  "ignore_labels": ["ignore changelog"],
  "max_pull_requests": 500,
  "max_back_track_time_days": 90,
  "base_branches": ["main"]
}
